fun countApplesAndOranges(s: Int, t: Int, a: Int, b: Int, apples: Array<Int>, oranges: Array<Int>): Unit {
    
  val appleOnHouse = getFruitCount(s, t, a, apples)
    val orangeOnHouse = getFruitCount(s, t, b, oranges)

    println(appleOnHouse)
    println(orangeOnHouse)
}

fun getFruitCount(
    houseStart: Int,
    houseEnd: Int,
    treePosition: Int,
    fruits: Array<Int>
): Int {

    var count = 0

    for (distance in fruits) {

        val landingPosition = treePosition + distance

        if (landingPosition >= houseStart &&
            landingPosition <= houseEnd) {

            count++
        }
    }

    return count
}
